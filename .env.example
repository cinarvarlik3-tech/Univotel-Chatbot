# Supabase / Postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Univotel CRM Postgres (read-only; used by `tag importConvo`)
CRM_DATABASE_URL=postgresql://user:password@host:5432/crm_dbname

# Chatwoot
CHATWOOT_BASE_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=your_chatwoot_api_token
CHATWOOT_ACCOUNT_ID=123
CHATWOOT_WEBHOOK_SECRET=your_hmac_shared_secret
CHATWOOT_BOT_AGENT_ID=456        # numeric ID of the ChatBot agent in Chatwoot

# Internal security (InfoGatherer <-> RecEngine)
INTERNAL_SHARED_SECRET=generate_a_random_secret_here

# LLM providers — store all keys/models; switch provider per task below.
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Default model per provider (MODEL_ID is legacy alias for GEMINI_MODEL_ID)
MODEL_ID=gemini-2.5-flash-lite
GEMINI_MODEL_ID=gemini-2.5-flash-lite
OPENAI_MODEL_ID=gpt-5.4-nano
ANTHROPIC_MODEL_ID=claude-haiku-4-5

# Per-task provider: gemini | openai | anthropic
TAGASSIGNER_PROVIDER=gemini
DIVERGENCE_PROVIDER=gemini

# Optional per-task model overrides (blank = use <PROVIDER>_MODEL_ID)
TAGASSIGNER_MODEL_ID=
DIVERGENCE_MODEL_ID=

# Shared LLM tuning
LLM_TEMPERATURE=0.0
LLM_REASONING_EFFORT=
LLM_MAX_OUTPUT_TOKENS=

# TagAssigner scheduling
# Set to false to disable idle-scan and nightly-batch auto-runs.
# Manual triggers (private "tag" note or "tag" label in Chatwoot) always work regardless.
TAGASSIGNER_AUTO_RUNS=true
# Standard Webhooks symmetric secret for Gemini batch.succeeded callbacks (base64-encoded).
# Generate with: python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
GEMINI_WEBHOOK_SECRET=your_base64_encoded_secret

# Optional: override log level (default: info)
LOG_LEVEL=info

# Testing mode: when true, the bot only responds to the two whitelisted test numbers.
# All other contacts are silently ignored — no DB writes, no messages, no processing.
# Set to false (or omit) in production.
TESTING_LIMITATIONS_MODE=false

# Live testing (Spec 022): admit up to N real conversations to the DB for safe validation.
# Mutually exclusive with TESTING_LIMITATIONS_MODE. Requires LIVE_TESTING_LIMIT when on.
LIVE_TESTING_MODE=false
# Cap is on total conversations rows. Start live testing from a clean/known table;
# existing rows count toward the limit.
LIVE_TESTING_LIMIT=

# When true, suppress all lead-facing outbound messages (send_with_retry). Labels,
# custom attributes, and private notes still write to Chatwoot.
OUTBOUND_BLOCK=false

INTEGRITY_CHECK_BYPASS=true

# Inbound debounce window in seconds (Spec 020). 0 = process each message immediately.
DEBOUNCE_WINDOW_SECONDS=3
